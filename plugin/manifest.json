{
  "manifest_version": 3,
  "name": "小星课堂助手",
  "version": "1.0.0",
  "description": "An AI assistant that integrates with learning platforms to provide smart course help.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>", "http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "小星设置"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["widget.css"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["widget.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
